#include "main.h"

/**
 * _puts - prints a string to the standard ouuput
 * @str: the string to print
 *
 * Return: void
 */
void _puts(char *str)
{
	char *ch;

	ch = &str[0];
	while (*ch != '\0')
	{
		_putchar(*ch);
		ch++;
	}

	_putchar('\n');
}
3-strcmp.c/     0           0     0     644     316       `
/**
 * _strcmp - compares two strings
 * @s1: the first string
 * @s2: the second string
 *
 * Return: 0 is s1 == s2,
 * >0 if first non-matching char in s1 > s2
 * <0 otherwise
 */
int _strcmp(char *s1, char *s2)
{
	while (*s1 == *s2)
	{
		if (*s1 == '\0')
			return (0);

		s1++;
		s2++;
	}
	return (*s1 - *s2);
}
3-strspn.c/     0           0     0     644     516       `
#include <stddef.h>

/**
 * _strspn - gets the length of a prefix substring
 * @s: the string to be scanned
 * @accept: string containing characters to be matched
 *
 * Return: number of bytes in @s before first mistmatch
 */
unsigned int _strspn(char *s, char *accept)
{
	int i;
	int j;
	int k;
	int len;

	k = 0;
	for (i  = 0; s[i] != '\0'; i++)
	{
		len = 0;
		for (j = 0; accept[j] != '\0'; j++)
		{
			if (s[i] == accept[j])
			{
				k++;
				len = 1;
			}
		}
		if (len == 0)
			return (k);
	}

	return (0);
}
